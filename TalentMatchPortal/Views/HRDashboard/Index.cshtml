@model Tuple<IEnumerable<TalentMatchPortal.Models.Job>, IEnumerable<TalentMatchPortal.Models.JobApplication>>

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2><i class="bi bi-speedometer2"></i> HR Admin Dashboard</h2>

        <div class="btn-group shadow-sm">
            <a asp-controller="Jobs" asp-action="Create" class="btn btn-primary btn-sm">
                <i class="bi bi-plus-circle"></i> Add New Job
            </a>
        </div>
    </div>
    <hr />

    <ul class="nav nav-pills mb-3" id="hrTab" role="tablist">
        <li class="nav-item">
            <button class="nav-link active" data-bs-toggle="tab" data-bs-target="#jobs">
                <i class="bi bi-briefcase"></i> Manage Jobs
            </button>
        </li>
        <li class="nav-item">
            <button class="nav-link" data-bs-toggle="tab" data-bs-target="#apps">
                <i class="bi bi-people"></i> Job Applications
            </button>
        </li>
    </ul>

    <div class="tab-content border p-3 rounded bg-white shadow-sm">
        <div class="tab-pane fade show active" id="jobs">
            <h4 class="mb-3">Active Job Postings</h4>
            <table class="table table-striped align-middle">
                <thead class="table-dark">
                    <tr>
                        <th>Job Title</th>
                        <th>Location</th>
                        <th class="text-center">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var job in Model.Item1)
                    {
                        <tr>
                            <td><strong>@job.Title</strong></td>
                            <td><i class="bi bi-geo-alt"></i> @job.Location</td>
                            <td class="text-center">
                                <a asp-controller="HRDashboard" asp-action="Edit" asp-route-id="@job.Id" class="btn btn-sm btn-warning">
                                    <i class="bi bi-pencil"></i> Edit
                                </a>
                                <form asp-controller="HRDashboard" asp-action="Delete" asp-route-id="@job.Id" method="post"
                                      onsubmit="return confirm('Are you sure you want to delete this job?');" style="display:inline;">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-sm btn-danger">
                                        <i class="bi bi-trash"></i> Delete
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="tab-pane fade" id="apps">
            <h4 class="mb-3">Incoming Applications</h4>
            <table class="table table-hover align-middle">
                <thead class="table-light">
                    <tr>
                        <th>Candidate</th>
                        <th>Job Title</th>
                        <th>Status</th>
                        <th>Exam Score</th>
                        <th>Resume</th>
                        <th class="text-end">Recruitment Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var app in Model.Item2)
                    {
                        <tr>
                            <td>
                                <div><strong>@app.User.FirstName</strong></div>
                                <small class="text-muted">@app.User.Email</small>
                                @if (app.User.Role == "Employee")
                                {
                                    <br />
                                    <span class="badge bg-primary mt-1"><i class="bi bi-patch-check"></i> Hired Employee</span>
                                }
                            </td>
                            <td>@app.Job.Title</td>
                            <td>
                                <span class="badge @(app.Status == "Shortlisted" ? "bg-info" :
                                                                                     app.Status == "Rejected" ? "bg-danger" :
                                                                                     app.Status == "Offered" ? "bg-success" :
                                                                                     app.Status == "Hired" ? "bg-primary" : "bg-warning text-dark")">
                                @app.Status
                            </span>
                        </td>
                        <td>
                            @if (app.Status != "Pending")
                                {
                                    var scoreClass = (app.ExamScore >= 12) ? "text-success" : "text-danger";
                                    <span class="fw-bold @scoreClass">
                                        <i class="bi bi-journal-check"></i> @(app.ExamScore?.ToString() ?? "0") / 20
                                    </span>
                                }
                                else
                                {
                                    <span class="text-muted small italic">Not Scheduled</span>
                                }
                            </td>
                            <td>
                                @if (!string.IsNullOrEmpty(app.ResumePath))
                                {
                                    <a href="/uploads/@app.ResumePath" target="_blank" class="btn btn-sm btn-outline-primary">
                                        <i class="bi bi-file-earmark-pdf"></i> View
                                    </a>
                                }
                            </td>
                            <td class="text-end">
                                <div class="d-flex justify-content-end gap-2">
                                    @if (app.Status == "Pending")
                                    {
                                        <form asp-action="Shortlist" method="post">
                                            <input type="hidden" name="appId" value="@app.Id" />
                                            <button type="submit" class="btn btn-sm btn-success">Shortlist</button>
                                        </form>
                                        <form asp-action="Reject" method="post" onsubmit="return confirm('Reject this candidate?');">
                                            <input type="hidden" name="appId" value="@app.Id" />
                                            <button type="submit" class="btn btn-sm btn-outline-danger">Reject</button>
                                        </form>
                                    }

                                    @if (app.Status == "Shortlisted")
                                    {
                                        if (app.ExamScore >= 6)
                                        {
                                            <form asp-action="SendOfferLetter" method="post">
                                                <input type="hidden" name="appId" value="@app.Id" />
                                                <button type="submit" class="btn btn-sm btn-primary">
                                                    <i class="bi bi-send"></i> Send Offer
                                                </button>
                                            </form>
                                        }
                                        else if (app.ExamScore > 0 && app.ExamScore < 6)
                                        {
                                            <form asp-action="Reject" method="post">
                                                <input type="hidden" name="appId" value="@app.Id" />
                                                <button type="submit" class="btn btn-sm btn-danger">Reject (Failed)</button>
                                            </form>
                                        }
                                        else
                                        {
                                            <span class="badge bg-light text-dark border p-2 small">Awaiting Result</span>
                                        }
                                    }

                                    @if (app.Status == "Offered" && app.User.Role == "Candidate")
                                    {
                                        <form asp-action="HireCandidate" method="post">
                                            <input type="hidden" name="candidateId" value="@app.User.Id" />
                                            <button type="submit" class="btn btn-sm btn-success shadow-sm"
                                                    onclick="return confirm('This will turn the candidate into an Employee. Continue?')">
                                                <i class="bi bi-person-plus-fill"></i> Hire Now
                                            </button>
                                        </form>
                                    }

                                    @if (app.User.Role == "Employee")
                                    {
                                        <button class="btn btn-sm btn-secondary" disabled>
                                            <i class="bi bi-check-all"></i> Onboarded
                                        </button>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">