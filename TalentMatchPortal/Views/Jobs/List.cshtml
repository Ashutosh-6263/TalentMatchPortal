@model IEnumerable<TalentMatchPortal.Models.Job>

<div class="container py-5">
    <div class="text-center mb-5">
        <h2 class="fw-bold display-5">Explore Opportunities</h2>
        <p class="text-muted">Find the perfect role matching your department and skills.</p>
        <div class="mx-auto" style="width: 60px; height: 4px; background-color: #0d6efd; border-radius: 2px;"></div>
    </div>

    @if (TempData["Message"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show shadow-sm" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i> @TempData["Message"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="row">
        @foreach (var item in Model)
        {
            <div class="col-lg-4 col-md-6 mb-4">
                <div class="card h-100 shadow-sm border-0 hover-lift transition">
                    <div class="card-body p-4">
                        <div class="d-flex justify-content-between align-items-start mb-3">
                            <span class="badge bg-primary-soft text-primary px-3 py-2">Full-Time</span>
                            <h6 class="text-success fw-bold mb-0">@item.SalaryRange</h6>
                        </div>

                        <h4 class="card-title fw-bold text-dark mb-2">@item.Title</h4>
                        <p class="text-muted small mb-3">
                            <i class="bi bi-geo-alt-fill me-1"></i> @item.Location
                        </p>

                        <p class="card-text text-secondary mb-4" style="display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden;">
                            @item.Description
                        </p>

                        <button type="button" class="btn btn-outline-primary w-100 fw-bold"
                                data-bs-toggle="modal"
                                data-bs-target="#applyModal-@item.Id">
                            Apply Now
                        </button>
                    </div>
                </div>
            </div>

            <div class="modal fade" id="applyModal-@item.Id" tabindex="-1" aria-hidden="true">
                <div class="modal-dialog modal-dialog-centered">
                    <div class="modal-content border-0 shadow-lg">
                        <div class="modal-header bg-primary text-white">
                            <h5 class="modal-title fw-bold">Apply for @item.Title</h5>
                            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                        </div>
                        <form asp-controller="Jobs" asp-action="Apply" method="post" enctype="multipart/form-data">
                            <div class="modal-body p-4">
                                <input type="hidden" name="jobId" value="@item.Id" />

                                <div class="text-center mb-4">
                                    <i class="bi bi-cloud-arrow-up display-4 text-primary"></i>
                                    <p class="text-muted small">Please upload your latest resume to complete the application.</p>
                                </div>

                                <div class="mb-3">
                                    <label class="form-label fw-bold">Resume (PDF/Docx)</label>
                                    <input type="file" name="resumeFile" class="form-control" required />
                                </div>
                            </div>
                            <div class="modal-footer bg-light">
                                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                                <button type="submit" class="btn btn-primary px-4">Submit Application</button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

<style>
    .bg-primary-soft {
        background-color: rgba(13, 110, 253, 0.1);
    }

    .hover-lift {
        transition: transform 0.2s ease, box-shadow 0.2s ease;
    }

        .hover-lift:hover {
            transform: translateY(-8px);
            box-shadow: 0 1rem 3rem rgba(0,0,0,0.175) !important;
        }

    .card-title {
        min-height: 3rem;
    }
</style>

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">