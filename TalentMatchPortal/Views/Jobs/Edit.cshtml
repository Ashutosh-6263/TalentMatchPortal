@model TalentMatchPortal.Models.Job

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow border-0">
                <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center">
                    <h4 class="mb-0">Edit Job: @Model.Title</h4>
                    <a asp-controller="HRDashboard" asp-action="Index" class="btn btn-outline-light btn-sm">Back to Dashboard</a>
                </div>
                <div class="card-body p-4">
                    <form asp-controller="HRDashboard" asp-action="Edit" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                        <input type="hidden" asp-for="Id" />

                        <div class="row">
                            <div class="col-md-12 mb-3">
                                <label asp-for="Title" class="form-label font-weight-bold"></label>
                                <input asp-for="Title" class="form-control" placeholder="Enter Job Title" />
                                <span asp-validation-for="Title" class="text-danger"></span>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label asp-for="Location" class="form-label font-weight-bold"></label>
                                <input asp-for="Location" class="form-control" placeholder="City, State" />
                                <span asp-validation-for="Location" class="text-danger"></span>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label asp-for="SalaryRange" class="form-label font-weight-bold"></label>
                                <input asp-for="SalaryRange" class="form-control" placeholder="e.g. 5 LPA - 8 LPA" />
                                <span asp-validation-for="SalaryRange" class="text-danger"></span>
                            </div>

                            <div class="col-md-12 mb-3">
                                <label asp-for="Description" class="form-label font-weight-bold"></label>
                                <textarea asp-for="Description" class="form-control" rows="5" placeholder="Detailed job requirements..."></textarea>
                                <span asp-validation-for="Description" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="d-grid gap-2 d-md-flex justify-content-md-end mt-4">
                            <button type="submit" class="btn btn-primary px-4">Update Job Posting</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}